/*
 * Nextflow Configuration File
 * PlantSC-Analyzer
 */

// Manifest
manifest {
    name            = 'PlantSC-Analyzer'
    author          = 'Cherry'
    homePage        = 'https://github.com/YOUR_USERNAME/plantsc-analyzer'
    description     = 'Plant single-cell RNA-seq analysis pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0-alpha'
}

// Default parameters
params {
    // Project info
    project_name    = 'PlantSC_Analysis'
    species         = 'arabidopsis'
    tissue          = 'root'

    // Input/Output
    data_type       = 'matrix'  // 'fastq' or 'matrix'
    sample_sheet    = null
    outdir          = './results'

    // Matrix generation (Step 0)
    matrix_generation {
        platform        = 'auto'  // auto, BGI, 10X
        bgi {
            kit_version     = 'auto'
            trim_oligo      = true
        }
        tenx {
            chemistry       = 'auto'
        }
    }

    // QC parameters (Step 1)
    qc {
        min_genes           = 200
        max_genes           = 6000
        min_cells           = 3
        mito_threshold      = 5.0
        mito_prefix         = 'ATMG'  // ATMG for Arabidopsis, OSMT for Rice
        doublet_threshold   = 0.25
        run_soupx           = true
        run_scrublet        = true
    }

    // Normalization (Step 2)
    normalize {
        method              = 'log1p'
        target_sum          = 10000
        n_hvg               = 3000
        hvg_flavor          = 'seurat'
        hvg_batch_key       = null
        scale               = true
    }

    // Integration (Step 3)
    integration {
        run                 = false
        method              = 'harmony'  // harmony, scvi, scanorama
        batch_key           = 'batch'
        harmony {
            n_pcs           = 50
            theta           = 2.0
        }
        scvi {
            n_latent        = 30
            n_layers        = 2
            n_epochs        = 400
        }
    }

    // Clustering (Step 4)
    cluster {
        n_neighbors         = 15
        n_pcs               = 50
        resolution          = [0.4, 0.6, 0.8, 1.0]
        algorithm           = 'leiden'
        metric              = 'euclidean'
    }

    // Annotation (Step 5)
    annotation {
        // Use verified marker database with real PMIDs
        marker_database     = './knowledge_base/markers/arabidopsis/root_markers_verified.csv'
        confidence_threshold = 0.7

        // LLM-assisted annotation (optional)
        use_llm             = false
        llm_provider        = 'openai'    // openai, anthropic
        llm_model           = 'gpt-4'     // gpt-4, gpt-3.5-turbo, claude-3-opus
        llm_api_key         = null         // Set via environment: OPENAI_API_KEY or ANTHROPIC_API_KEY
        llm_n_genes         = 20           // Number of marker genes to send to LLM
    }

    // Downstream (Step 6)
    downstream {
        deg {
            run                 = true
            method              = 'wilcoxon'
            min_pct             = 0.1
            logfc_threshold     = 0.25
        }
        enrichment {
            run                 = false
            organism            = 'arabidopsis'
            databases           = ['GO', 'KEGG']
        }
        trajectory {
            run                 = false
            method              = 'paga'  // paga, monocle3, slingshot
            root_cell_type      = null
        }
    }

    // Compute resources
    max_cpus            = 16
    max_memory          = '64.GB'
    max_time            = '48.h'

    // Help
    help                = false
}

// Process configuration
process {
    // Default resources
    cpus   = 4
    memory = '16.GB'
    time   = '4.h'

    // Error handling
    errorStrategy = 'retry'
    maxRetries    = 2

    // Process-specific resources
    withLabel: 'low_cpu' {
        cpus   = 2
        memory = '8.GB'
    }

    withLabel: 'medium_cpu' {
        cpus   = 8
        memory = '32.GB'
    }

    withLabel: 'high_cpu' {
        cpus   = 16
        memory = '64.GB'
    }

    withLabel: 'gpu' {
        queue = 'gpu'
        clusterOptions = '--gres=gpu:1'
    }
}

// Executor profiles
profiles {
    // Local execution
    standard {
        process.executor = 'local'
    }

    // Docker
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'plantsc-analyzer:latest'
    }

    // Singularity
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process.container = 'plantsc-analyzer.sif'
    }

    // SLURM cluster
    slurm {
        process {
            executor = 'slurm'
            queue = 'normal'
            clusterOptions = '--account=YOUR_ACCOUNT'
        }
        executor {
            queueSize = 50
            submitRateLimit = '10 sec'
        }
    }

    // PBS cluster
    pbs {
        process {
            executor = 'pbs'
            queue = 'batch'
        }
    }

    // Test profile (small dataset)
    test {
        params {
            sample_sheet = './tests/test_data/sample_sheet.csv'
            outdir = './test_results'
            qc.min_genes = 100
            normalize.n_hvg = 1000
        }
        process {
            cpus = 2
            memory = '4.GB'
        }
    }
}

// Reporting
timeline {
    enabled = true
    file    = "${params.outdir}/timeline.html"
}

report {
    enabled = true
    file    = "${params.outdir}/report.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/trace.txt"
}

dag {
    enabled = true
    file    = "${params.outdir}/dag.svg"
}

// Cleanup
cleanup = true
